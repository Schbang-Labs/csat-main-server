{
  "name": "csat-server",
  "version": "1.0.0",
  "description": "CSAT Server - Production-grade API for customer satisfaction data processing",
  "main": "server.js",
  "imports": {
    "#src/*": "./src/*",
    "#config/*": "./src/config/*",
    "#controllers/*": "./src/controllers/*",
    "#middleware/*": "./src/middleware/*",
    "#models/*": "./src/models/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./src/utils/*",
    "#validations/*": "./src/validations/*"
  },
  "scripts": {
    "start": "node --import ./src/tracing.js src/server.js",
    "dev": "nodemon --exec \"node --import ./src/tracing.js src/server.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "migrate:service-strategy": "node scripts/migrateServiceStrategy.js",
    "migrate:csat-version-v1": "node scripts/backfillCsatVersionV1.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Schbang-Labs/csat-main-server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Schbang-Labs/csat-main-server.git/issues"
  },
  "homepage": "https://github.com/Schbang-Labs/csat-main-server.git#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.215.0",
    "@opentelemetry/host-metrics": "^0.38.3",
    "@opentelemetry/instrumentation-winston": "^0.59.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@opentelemetry/winston-transport": "^0.25.0",
    "bcrypt": "^6.0.0",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pdfmake": "^0.3.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "xlsx": "^0.18.5"
  }
}
