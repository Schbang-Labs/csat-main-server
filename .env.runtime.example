# ============================================================
# CSAT Backend — Runtime Environment Template
# ------------------------------------------------------------
# Copy to `.env.runtime` (gitignored) and fill in real values.
# In production these values are managed in the Dockploy UI.
# NEVER put real credentials in this file — it's committed to git.
# ============================================================

# ===========================================
# Server
# ===========================================
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
# JSON array of allowed CORS origins
FRONTEND_URL=["https://your-frontend.example.com","http://localhost:3000"]

# ===========================================
# MongoDB Atlas
# ===========================================
# mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=...
MONGO_URI=

# ===========================================
# Auth secrets — generate fresh, never reuse
#   openssl rand -base64 64    # for JWT_SECRET
#   openssl rand -hex 32       # for APP_SECRET / ADMIN_CLIENT_SECRET / MONITOR_SECRET
# ===========================================
JWT_SECRET=
APP_SECRET=
ADMIN_CLIENT_SECRET=
MONITOR_SECRET=

# ===========================================
# AWS — S3 backups + SQS queue + SES API (used by app SDK)
# ===========================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=csat-db-backup

# ===========================================
# SES — used by APP CODE (AWS SDK, not Alertmanager)
# Powers in-app email features (e.g. CSAT result mails).
# Alertmanager uses the SMTP block below — different auth mechanism.
# ===========================================
SES_FROM_EMAIL=
SES_TO_EMAILS=
SES_ALERTS_ENABLED=true
SES_CONFIGURATION_SET=

# ===========================================
# OpenRouter (LLM)
# ===========================================
OPENROUTER_API_KEY=

# ===========================================
# AWS SES via SMTP — used by ALERTMANAGER for alert emails
# -----------------------------------------------------------
# SES SMTP credentials are SEPARATE from IAM API keys above.
# Two ways to get them:
#   (a) Generate dedicated creds: AWS Console → SES → SMTP Settings →
#       "Create SMTP Credentials"
#   (b) DERIVE from any IAM user's secret + region using AWS's standard
#       HMAC-SHA256 algorithm. SMTP_USERNAME = IAM access key ID;
#       SMTP_PASSWORD = derived value. Re-derive whenever the IAM
#       secret rotates.
#
# Endpoint format: email-smtp.<region>.amazonaws.com
# ===========================================
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REQUIRE_TLS=true
# Comma-separated lists OK for multiple recipients
ALERT_EMAIL_CRITICAL=
ALERT_EMAIL_WARNING=

# ===========================================
# Observability stack — used by infra/observability
# ===========================================
# Bind interface (127.0.0.1 = localhost-only, safe default).
# Override to 0.0.0.0 only if you need LAN access during dev.
OBS_BIND_IP=127.0.0.1

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_PORT=3001

# Internal-only ports (Traefik handles public access in prod)
VM_PORT=8428
VLOGS_PORT=9428
ALERTMANAGER_PORT=9093
VMALERT_PORT=8880

# MinIO root creds (Tempo's S3 backend) — generate fresh
#   openssl rand -base64 32
MINIO_ROOT_USER=tempo_user
MINIO_ROOT_PASSWORD=

# ===========================================
# Public domains for Traefik routing in production
# ===========================================
# API_DOMAIN=api.your-domain.com
# GRAFANA_DOMAIN=grafana.your-domain.com

# ===========================================
# Build label (optional)
# ===========================================
# APP_VERSION=$(git rev-parse --short HEAD)
