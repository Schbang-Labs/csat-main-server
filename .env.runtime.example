# ===========================================================
# CSAT Backend — Runtime Environment (template)
# -----------------------------------------------------------
# Copy this file to `.env.runtime` and fill in real values.
# `.env.runtime` is git-ignored and consumed by docker-compose
# via `env_file:`. In production these values are managed in
# the Dockploy UI (per-environment) and substituted at deploy.
# ===========================================================

# --- Server ---
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# JSON array of allowed CORS origins
FRONTEND_URL=["https://your-frontend.example.com","http://localhost:3000"]

# --- MongoDB Atlas ---
# mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=...
MONGO_URI=

# --- Auth ---
JWT_SECRET=
APP_SECRET=
ADMIN_CLIENT_SECRET=

# --- AWS (S3 backups + SQS queue) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=csat-db-backup

# --- SES via AWS SDK (used by APP CODE — different from Alertmanager SMTP below) ---
# Powers in-app SES email features (e.g. CSAT result mails).
SES_FROM_EMAIL=
SES_TO_EMAILS=
SES_ALERTS_ENABLED=true
SES_CONFIGURATION_SET=
MONITOR_SECRET=

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=

# --- Optional dev flags (ignored in production) ---
# CLEAN_DB=true
# SEED_DATA=true

# ===========================================================
# OBSERVABILITY STACK — env vars consumed by infra/observability
# ===========================================================
# Used by Grafana / VictoriaMetrics / VictoriaLogs / Tempo / Alertmanager.
# Source these from .env.runtime when bringing up the obs stack:
#   docker compose -f infra/observability/docker-compose.yml --env-file .env.runtime up -d

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_PORT=3001

# --- Bind interface for obs ports (127.0.0.1 = localhost only — safe default) ---
OBS_BIND_IP=127.0.0.1

# --- Port overrides (rarely needed) ---
VM_PORT=8428
VLOGS_PORT=9428
ALERTMANAGER_PORT=9093
VMALERT_PORT=8880

# --- MinIO root creds (Tempo trace storage backend) ---
MINIO_ROOT_USER=tempo_user
MINIO_ROOT_PASSWORD=tempo_password_change_me

# ===========================================================
# ALERTMANAGER → AWS SES (SMTP interface)
# ===========================================================
# We use SES via its SMTP endpoint (not the API) because Alertmanager
# only speaks SMTP natively. The SMTP creds below are NOT your regular
# IAM access keys — SES requires a SEPARATE pair generated via:
#
#   AWS Console → Amazon SES → SMTP Settings → "Create SMTP Credentials"
#   (This actually creates a tiny IAM user with a single ses:SendRawEmail
#    permission and gives you the SMTP-formatted username + password.)
#
# Endpoint format: email-smtp.<region>.amazonaws.com
# Match the region to where your SES identity is verified.
# Your AWS_REGION elsewhere in this file (ap-south-1) is for S3/SQS;
# it's fine for SES to be the same OR a different region.

SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
# SES SMTP username — looks like AKIA... but is NOT your IAM access key
SMTP_USERNAME=
# SES SMTP password — looks like a 44-char base64 string
SMTP_PASSWORD=
# FROM address — MUST be a verified identity in SES (email or domain)
SMTP_FROM=alerts@yourdomain.com
SMTP_REQUIRE_TLS=true

# Comma-separated recipients OK.
# IMPORTANT: if your SES account is still in the SANDBOX (default for new
# accounts), every recipient address below ALSO has to be verified in SES.
# To send to anyone, request production access in SES → Account Dashboard.
ALERT_EMAIL_CRITICAL=oncall@yourdomain.com
ALERT_EMAIL_WARNING=devops@yourdomain.com

# --- Build-time tag (optional, used to label the built image) ---
# APP_VERSION=$(git rev-parse --short HEAD)
